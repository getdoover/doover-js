{
  "name": "doover-js",
  "version": "0.1.0",
  "description": "TypeScript client for Doover.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/get-doover/doover-js.git"
  },
  "homepage": "https://github.com/get-doover/doover-js#readme",
  "bugs": {
    "url": "https://github.com/get-doover/doover-js/issues"
  },
