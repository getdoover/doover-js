    "@types/sinon": "^17.0.4",
    "chai": "^5.2.1",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.1.0",
    "sinon": "^21.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
